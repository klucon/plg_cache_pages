{
  "schema_version": "1.0",
  "name": "plg_cache_pages",
  "type": "plugin",
  "vendor": "klucon",
  "extension_id": "klucon/plg_cache_pages",
  "version": "0.1.1",
  "display_name": "Cache stránek",
  "display_name_key": "extensions.name.plg_cache_pages",
  "description": "In-memory TTL cache s admin rozhraním. Ostatní rozšíření ji mohou využívat přes page_cache API. Automaticky invaliduje při změně obsahu.",
  "license": "MIT",
  "author": {
    "name": "KLUCON",
    "url": "https://klucon.cz"
  },
  "links": {
    "homepage": "https://marketplace.klucon.cz",
    "repository": "https://github.com/klucon/plg_cache_pages"
  },
  "compatibility": {
    "core_min": "0.2.0",
    "core_max": null,
    "python": ">=3.12",
    "database": [
      "mysql",
      "postgresql"
    ]
  },
  "package": {
    "entrypoint": "src.plugins.plg_cache_pages",
    "setup_function": "setup",
    "admin_router": "admin.router"
  },
  "permissions": [
    {
      "key": "cache.manage",
      "label": "permissions.cache.manage"
    }
  ],
  "i18n": {
    "domain": "plg_cache_pages",
    "locales_path": "i18n",
    "required_locales": [
      "cs_CZ",
      "en_GB"
    ]
  },
  "migrations": {
    "enabled": false,
    "path": "migrations"
  },
  "security": {
    "requires_signature": true,
    "capabilities": [
      "plugin.hooks",
      "admin.routes",
      "database.read",
      "database.write"
    ]
  },
  "marketplace": {
    "category": "performance",
    "tags": [
      "cache",
      "performance",
      "ttl",
      "memory"
    ],
    "featured": false
  },
  "changelog": "První vydání: in-memory TTL cache, admin UI se statistikami, automatická invalidace při content hooks."
}
